# ============================================================
# .gitignore — Node.js + Docker Microservices Project
# ============================================================

# --------------------------
# Environment / Secrets
# --------------------------
.env
.env.*
**/.env
**/.env.*
!**/.env.example          # Allow example env template files to be committed

# --------------------------
# Dependencies
# --------------------------
node_modules/
**/node_modules/

# --------------------------
# Build / Distribution
# --------------------------
dist/
**/dist/
build/
**/build/
.next/
out/

# --------------------------
# Logs
# --------------------------
logs/
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --------------------------
# Runtime / OS
# --------------------------
*.pid
*.seed
*.pid.lock
.DS_Store
Thumbs.db

# --------------------------
# Test & Coverage
# --------------------------
coverage/
**/coverage/
.nyc_output/

# --------------------------
# IDE / Editor
# --------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --------------------------
# Docker (local overrides only)
# --------------------------
docker-compose.override.yml

# --------------------------
# Misc
# --------------------------
.cache/
.temp/
tmp/

# ============================================================
# NOT ignored (explicitly safe):
#   *.md files      — README, DOCS, RUNBOOK, etc.
#   .gitignore      — this file
#   Dockerfiles     — needed for builds
#   docker-compose.yml
# ============================================================
